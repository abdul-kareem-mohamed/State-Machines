clock x;
const int Max_Que = 10;
int curr_floor, dest_floor, Q = 0;
int requestQueue[Max_Que];

void enqueue(int dest_floor,int dir){
    if(Q &lt; Max_Que){
    requestQueue[Q] = dest_floor;
    Q++;
    }
}

void dequeue(){
int i;
if(Q &gt; 0){
    for(i = 0; i &lt; Q-1; i++){
        requestQueue[i] = requestQueue[i+1];
    }
    requestQueue[Q-1] = 0;
    Q--;
  }
}   </declaration>
